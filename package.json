{
  "name": "suomisanat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "node scripts/run-vitest.mjs",
    "test:watch": "node scripts/run-vitest.mjs --watch",
    "test:e2e": "npm run build:e2e && playwright test",
    "verify": "eslint . && tsc -b --pretty false && node scripts/run-vitest.mjs && tsc -b && vite build",
    "supabase:link": "supabase link",
    "supabase:migration:list": "supabase migration list --linked",
    "supabase:migration:baseline": "supabase migration repair 20260323120000 --status applied --linked",
    "supabase:db:push": "supabase db push --linked",
    "supabase:db:push:dry": "supabase db push --linked --dry-run",
    "supabase:db:reset": "supabase db reset --local",
    "supabase:db:lint": "supabase db lint --local"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "supabase": "^2.83.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
